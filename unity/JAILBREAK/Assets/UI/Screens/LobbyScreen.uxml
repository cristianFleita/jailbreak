<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/Screens/LobbyUI.uss?fileID=7433441132597879392&amp;guid=02e1c9c1efafe4986b4182633f99d7c0&amp;type=3#LobbyUI"/>
    <ui:VisualElement name="root" class="screen-root" style="background-image: url(&quot;project://database/Assets/UI/Sprites/bg_lobby.png?fileID=2800000&amp;guid=e546b364807cd4565b4eefd1ba1bec2f&amp;type=3#bg_lobby&quot;);">
        <ui:VisualElement name="top-bar" class="top-bar">
            <ui:VisualElement class="top-bar-spacer"/>
