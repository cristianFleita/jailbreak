                <ui:VisualElement name="logo-icon" class="logo-icon" style="background-image: url(&quot;project://database/Assets/UI/Sprites/lobby-screen-spreadsheet.png?fileID=1596809197&amp;guid=06274fbf9d35d42d693f35b3152f8cf8&amp;type=3#lobby-screen-spreadsheet_0&quot;);"/>
            </ui:VisualElement>
            <ui:VisualElement class="profile-container">
